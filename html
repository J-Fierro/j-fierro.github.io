<!DOCTYPE html>
<html>
<head>
  <style>
    body { margin: 0; padding: 0; overflow: hidden; }
    
    iframe {
      width: 270%;
      height: 70vh;
      border: none; 
      transform-origin: top left;
    transform: scale(0.525);
    }
    
    /* Overlay que bloquea toda interacción */
    .overlay {
      position: fixed;
      top: 0; left: 0;
      width: 100%;
      height: 100%;
      z-index: 999;
      background: transparent;
      pointer-events: all;
    }
  </style>
</head>
<body>
  <div class="overlay"></div>
  <iframe src="https://docs.google.com/spreadsheets/d/1FB2a0IusIJT8_RkMwRzQZj_SaV-eRrSP7cnYKEyaEp8/edit?usp=sharing"></iframe>
</body>
</html>
